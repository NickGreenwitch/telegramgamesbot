{
  "name": "telegram-party-games",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram Mini App with party games (Mafia, D&D)",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "cd server && npm run dev",
    "dev:web": "cd web && npm run dev",
    "build": "npm run build:web && npm run build:server",
    "build:server": "cd server && npm run build",
    "build:web": "cd web && npm run build"
  },
  "workspaces": [
    "shared",
    "server",
    "bot",
    "web"
  ],
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NickGreenwitch/telegramgamesbot.git"
  }
}
